#!/bin/sh
set -e

cd "${0%/*}" || exit 1

PYTHONDONTWRITEBYTECODE=1
export PYTHONDONTWRITEBYTECODE

./generate_dodecagon_geometry.py --check
./validate_case.py
./validate_contact_predicates.py
./validate_polygon_prism_sampling.py
./validate_moving_wall_geometry.py
./validate_velocity_projection.py

if command -v blockMesh >/dev/null 2>&1 \
    && command -v topoSet >/dev/null 2>&1 \
    && command -v checkMesh >/dev/null 2>&1
then
    blockMesh
    topoSet
    checkMesh -allGeometry -allTopology
else
    echo "OpenFOAM mesh tools are unavailable; static regressions passed."
fi
