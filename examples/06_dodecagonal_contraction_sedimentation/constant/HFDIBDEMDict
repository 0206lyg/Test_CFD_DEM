FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      HFDIBDEMDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

bodyNames ( "PH_SC_reservoir" );

interpolationSchemes
{
  //~ U cellPointFace;
  U cell;
}

surfaceThreshold    1e-4;
stepDEM     0.01;
geometricD (1 1 1);
recordSimulation true;
recordFirstTimeStep true;
// Intentional validation-stage cap. Raise this after polygon-prism/contact
// validation when approaching the fieldValue 0.3 production target.
nSolidsInDomain 1000;

outputSetup
{
    basic false;
    iB  false;
    DEM false;
    addModel false;
    parallelDEM false;
}

DEM
{
    LcCoeff 4.0;
    // rotationModel chen2012;
    // rotationModel mindlin1953

    materials
    {
        particle
        {
            Y       5e8;
            nu      0.5;
            mu      1.0;
            adhN    0;
            eps     0.75;
        }

        wall
        {
            Y       5e8;
            nu      0.5;
            mu      1.0;
            adhN    0;
            eps     0.75;
        }
    }

    cyclicPatches
    {
    }

    collisionPatches
    {
        // Single source with system/blockMeshDict; generated by
        // generate_dodecagon_geometry.py.
        #include "dodecagonCollisionPatches"
    }
}

virtualMesh
{
    level 4;
    charCellSize 0.0005;
}

PH_SC_reservoir
{
    fullyCoupledBody
    {
        velocity (0 0 0);
    }

    rho         rho [1 -3 0 0 0 0 0] 2500;

    refineMC 5;

    U
    {
        BC  noSlip;
    }

    bodyAddition
    {
        addModel onceScatter;
        onceScatterCoeffs
        {
            addMode fieldBased;
            fieldBasedCoeffs
            {
                fieldName lambda;
                fieldValue 0.3;
            }

            // Deterministic test seed; geometry and addDomain are generated
            // from the same dodecagon constants as blockMesh and DEM walls.
            randomSeed 1206;
            #include "dodecagonAdditionDomain"

            scalingMode    noScaling;
            noScalingCoeffs{}

            rotationMode   randomRotation;
            randomRotationCoeffs{}
        }
    }

    material particle;
    bodyGeom convex;
    updateTorque true;
    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers 0;
    timesToSetStatic -1;
}

// ************************************************************************* //
