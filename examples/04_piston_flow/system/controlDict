FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pimpleLYJHFDIBFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         90.0;

deltaT          1e-3;

writeControl    adjustableRunTime;

writeInterval   0.9;

purgeWrite      0;

writeFormat     ascii;

writePrecision  8;

writeCompression uncompressed;

timeFormat      general;

timePrecision   8;

maxCo           1.0;

maxDeltaT       0.002;

adjustTimeStep  yes;

runTimeModifiable yes;

functions
{
    pistonFluidForce
    {
        type            forces;
        libs            ("libforces.so");

        writeControl    timeStep;
        writeInterval   1;

        patches         (topOpen);
        rho             rhoInf;
        rhoInf          1000;
        CofR            (0 0 0);
    }
}

