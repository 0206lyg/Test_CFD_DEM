FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    topOpen
    {
        type            fixedValue;
        value           uniform 0;
    }

    bottomWall
    {
        type            zeroGradient;
    }

    contractionWall
    {
        type            zeroGradient;
    }
    
    xMinWall
    {
        type            zeroGradient;
    }

    xMaxWall
    {
        type            zeroGradient;
    }

    zMinWall
    {
        type            zeroGradient;
    }

    zMaxWall
    {
        type            zeroGradient;
    }
}

