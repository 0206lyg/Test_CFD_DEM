FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      HFDIBDEMDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

bodyNames ( "PH_SC_reservoir" );

interpolationSchemes
{
  //~ U cellPointFace;
  U cell;
}

surfaceThreshold    1e-4;
stepDEM     0.01;
geometricD (1 1 1);
recordSimulation true;
recordFirstTimeStep true;
nSolidsInDomain 1000;       //Sets Upper Limit On Number Of Particles In Domain if not spcecified sets to 1000 by default


outputSetup
{
    basic false;
    iB  false;
    DEM false;
    addModel false;
    parallelDEM false;
}
DEM
{
	LcCoeff 4.0;
	// rotationModel chen2012;
	// rotationModel mindlin1953

    materials
    {
        particle
        {
            Y       5e8;
            nu      0.5;
            mu      1.0;
            adhN    0;
            eps     0.75;
        }

        wall
        {
            Y       5e8;
            nu      0.5;
            mu      1.0;
            adhN    0;
            eps     0.75;
        }
    }

	cyclicPatches
	{
	} 
	
    collisionPatches
    {
        // ------------------------------------------------------------
        // Downstream 0.02 x 0.02 channel rotated 45 degrees about y.
        // All four patches are finite, inclined polygons.  This is the
        // regression geometry for orientation-independent wall contact.
        // ------------------------------------------------------------

        xMin_small
        {
            material    wall;
            nVec        (-0.707106781187 0 -0.707106781187);
            planePoint  (-0.00707106781187 0 -0.00707106781187);

            finitePatch true;
            vertices
            (
                ( 0                 0.00 -0.0141421356237)
                ( 0                 0.05 -0.0141421356237)
                (-0.0141421356237   0.05  0)
                (-0.0141421356237   0.00  0)
            );
        }

        xMax_small
        {
            material    wall;
            nVec        (0.707106781187 0 0.707106781187);
            planePoint  (0.00707106781187 0 0.00707106781187);

            finitePatch true;
            vertices
            (
                (0.0141421356237  0.00 0)
                (0.0141421356237  0.05 0)
                (0                0.05 0.0141421356237)
                (0                0.00 0.0141421356237)
            );
        }

        zMin_small
        {
            material    wall;
            nVec        (0.707106781187 0 -0.707106781187);
            planePoint  (0.00707106781187 0 -0.00707106781187);

            finitePatch true;
            vertices
            (
                (0                 0.00 -0.0141421356237)
                (0                 0.05 -0.0141421356237)
                (0.0141421356237   0.05  0)
                (0.0141421356237   0.00  0)
            );
        }

        zMax_small
        {
            material    wall;
            nVec        (-0.707106781187 0 0.707106781187);
            planePoint  (-0.00707106781187 0 0.00707106781187);

            finitePatch true;
            vertices
            (
                (-0.0141421356237  0.00 0)
                (-0.0141421356237  0.05 0)
                (0                 0.05 0.0141421356237)
                (0                 0.00 0.0141421356237)
            );
        }

        // ------------------------------------------------------------
        // Upstream 0.08 x 0.08 chamber, rotated by the same 45 degrees.
        // These four walls are finite polygons over the physical chamber
        // height.  This routes inclined corner contacts through the same
        // orientation-independent finite-wall path as the small channel.
        // ------------------------------------------------------------

        xMin_large
        {
            material    wall;
            nVec        (-0.707106781187 0 -0.707106781187);
            planePoint  (-0.0282842712475 0 -0.0282842712475);

            finitePatch true;
            vertices
            (
                ( 0                0.05 -0.056568542495)
                ( 0                0.15 -0.056568542495)
                (-0.056568542495   0.15  0)
                (-0.056568542495   0.05  0)
            );
        }

        xMax_large
        {
            material    wall;
            nVec        (0.707106781187 0 0.707106781187);
            planePoint  (0.0282842712475 0 0.0282842712475);

            finitePatch true;
            vertices
            (
                (0.056568542495  0.05 0)
                (0.056568542495  0.15 0)
                (0               0.15 0.056568542495)
                (0               0.05 0.056568542495)
            );
        }

        zMin_large
        {
            material    wall;
            nVec        (0.707106781187 0 -0.707106781187);
            planePoint  (0.0282842712475 0 -0.0282842712475);

            finitePatch true;
            vertices
            (
                (0               0.05 -0.056568542495)
                (0               0.15 -0.056568542495)
                (0.056568542495  0.15  0)
                (0.056568542495  0.05  0)
            );
        }

        zMax_large
        {
            material    wall;
            nVec        (-0.707106781187 0 0.707106781187);
            planePoint  (-0.0282842712475 0 0.0282842712475);

            finitePatch true;
            vertices
            (
                (-0.056568542495  0.05 0)
                (-0.056568542495  0.15 0)
                (0                0.15 0.056568542495)
                (0                0.05 0.056568542495)
            );
        }

        // ------------------------------------------------------------
        // Rotated contraction shoulder at y = 0.05.  The four convex
        // polygons cover the large diamond except for the small opening.
        //
        // nVec = (0 -1 0)
        // upstream side y > 0.05 is inside
        // penetration toward y < 0.05 through shoulder gives contact
        // ------------------------------------------------------------

        shoulder_zPlus
        {
            material    wall;
            nVec        (0 -1 0);
            planePoint  (0 0.05 0);

            finitePatch true;
            vertices
            (
                (-0.0381837661841 0.05 -0.0240416305603)
                ( 0.0240416305603 0.05  0.0381837661841)
                ( 0                 0.05  0.0622253967444)
                (-0.0622253967444 0.05  0)
            );
        }

        shoulder_zMinus
        {
            material    wall;
            nVec        (0 -1 0);
            planePoint  (0 0.05 0);

            finitePatch true;
            vertices
            (
                ( 0                 0.05 -0.0622253967444)
                ( 0.0622253967444  0.05  0)
                ( 0.0381837661841  0.05  0.0240416305603)
                (-0.0240416305603  0.05 -0.0381837661841)
            );
        }

        shoulder_xPlus
        {
            material    wall;
            nVec        (0 -1 0);
            planePoint  (0 0.05 0);

            finitePatch true;
            vertices
            (
                (0.0141421356237 0.05 0)
                (0.0381837661841 0.05 0.0240416305603)
                (0.0240416305603 0.05 0.0381837661841)
                (0               0.05 0.0141421356237)
            );
        }

        shoulder_xMinus
        {
            material    wall;
            nVec        (0 -1 0);
            planePoint  (0 0.05 0);

            finitePatch true;
            vertices
            (
                (-0.0240416305603 0.05 -0.0381837661841)
                ( 0                 0.05 -0.0141421356237)
                (-0.0141421356237 0.05  0)
                (-0.0381837661841 0.05 -0.0240416305603)
            );
        }
        
        bottomWall
        {
            material    wall;
            nVec        (0 -1 0);
            planePoint  (0 0 0);

            finitePatch true;
            vertices
            (
                (-0.0141421356237 0 0)
                (0 0 -0.0141421356237)
                (0.0141421356237 0 0)
                (0 0 0.0141421356237)
            );
        }
        
    }
}

virtualMesh
{
    level 4;
    charCellSize 0.0005;
}

PH_SC_reservoir
{

    fullyCoupledBody
    {
        velocity (0 0 0);
    }

    rho         rho [1 -3 0 0 0 0 0] 2500;

    refineMC 5;

    U
    {
        BC  noSlip;
    }

    bodyAddition
    {
        addModel onceScatter;
        onceScatterCoeffs
        {
            addMode fieldBased;
            fieldBasedCoeffs
            {
                fieldName lambda;
                fieldValue 0.3;
            }

            addDomain boundBox;
            boundBoxCoeffs
            {
                // The rotated chamber is a diamond in the global x-z plane.
                // Keep random placement inside its inscribed square; the
                // onceScatter model samples this Cartesian box directly.
                minBound (-0.028 0.05 -0.028);
                maxBound ( 0.028 0.15  0.028);
            }

            scalingMode    noScaling;
            noScalingCoeffs{}

            rotationMode   randomRotation;
            randomRotationCoeffs{}
        }
    }

    material particle;
    bodyGeom convex;
    updateTorque true;
    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers 0;
    timesToSetStatic -1;
}

